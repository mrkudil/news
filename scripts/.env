## =============================================================================
## BASE URLS & NETWORKING
## =============================================================================
SCRAPER_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36

## =============================================================================
## GLOBAL FILE PATHS
## =============================================================================
## For server deployment, uncomment the /home/alderson/public_html paths
## and comment out the local public_html defaults below.
#EMA_DATA_DIR=/home/alderson/public_html
#MOMENTUM_DATA_DIR=/home/alderson/public_html
#SCRAPER_OUTPUT_DIR=/home/alderson/public_html
#SCRAPER_LOG_FILE=/home/alderson/public_html/scraper.log
#MACRO_CALENDAR_JSON=/home/alderson/public_html/calendar.json
#MACRO_COMPONENT_CACHE=/home/alderson/public_html/macro_components_cache.json
#MACRO_CACHE_FILE=/home/alderson/public_html/macro_cache.json
#PIVOT_ALERT_STATE_FILE=/home/alderson/public_html/pivot_telegram_alerts.json
#SIGNAL_ALERT_STATE_FILE=/home/alderson/public_html/signal_telegram_alerts.json

MACRO_COMPONENTS_FILE=public_html/macro_components.json
PIVOT_LEVELS_FILE=public_html/pivot_levels.json
SIGNAL_ALERT_STATE_FILE=public_html/signal_telegram_alerts.json

## =============================================================================
## MACRO ENGINE (macro.py)
## =============================================================================
MACRO_DEBUG=0
MACRO_MAIN_PAIRS=eurusd,gbpusd,xauusd
MACRO_CACHE_TTL=1800
MACRO_DQ_MIN=0.4
MACRO_SCORE_MIN=0.8
MACRO_SCORE_STRONG=1.2
MACRO_VIX_DEAD=12
MACRO_VIX_RISK_OFF=24
STOOQ_BATCH_SLEEP=0.35



## =============================================================================
## MOMENTUM ENGINE (momentum.py)
## =============================================================================
MOMENTUM_MAIN_PAIRS=eurusd,gbpusd,xauusd

## Also read by signal_confirm.py via MOMENTUM_CLOSES_FILE fallback.
MOMENTUM_CLOSES_FILE=public_html/momentum_closes.json

## ---------------------------------------------------------------------------
## Live-price publishing for live-only pivot.py
## ---------------------------------------------------------------------------
## CRITICAL:
## pivot.py is now live-only. If macro_components.json does not contain
## price_current, pivot.py will correctly return:
##   state_basis=no_live_price
##   reason=missing_live_price
##
## momentum.py now publishes live prices into macro_components.json and rates.json.
MOMENTUM_PUBLISH_LIVE_CONTEXT=1
MOMENTUM_PUBLISH_RATES_JSON=1

## Shared live context file consumed by pivot.py.
MOMENTUM_LIVE_CONTEXT_FILE=public_html/macro_components.json

## Same live price feed for pivots.html NOW display.
MOMENTUM_RATES_FILE=public_html/rates.json

## Maximum acceptable live-price age, seconds.
## Keep aligned with your pivot live TTL expectation.
MOMENTUM_LIVE_PRICE_MAX_AGE=180

## H1 ATR-style close-to-close volatility proxy.
MOMENTUM_H1_ATR_PERIOD=14

## ---------------------------------------------------------------------------
## Unified Momentum + Pivot Telegram execution alerts
## ---------------------------------------------------------------------------
## Institutional-style alert combining:
## - H1 EMA alignment / momentum
## - H1 RSI
## - H1 ATR proxy
## - live pivot.py price_state
## - pivot ATR confirmation
## - pivot-zone entry / SL / TP trade plan
##
## Sends only when momentum direction and pivot direction align.
MOMENTUM_UNIFIED_EXECUTION_ALERTS=1

## Require pivot.py to have live price basis.
## Recommended ON. If pivot_state is no_live_price, no unified alert is sent.
MOMENTUM_UNIFIED_REQUIRE_PIVOT_LIVE=1

## Require pivot.py ATR confirmation before unified alert.
## Recommended OFF initially so valid aligned setups still alert even if ATR is unavailable.
## Turn ON later if you want stricter breakout/acceptance filtering.
MOMENTUM_UNIFIED_REQUIRE_ATR_CONFIRMED=0

## Minimum risk:reward from pivot.py trade_plan.risk_reward.best.
MOMENTUM_UNIFIED_MIN_RR=1.20

## De-duplication TTL for unified alerts.
## Prevents repeated institutional-style alerts for the same aligned condition.
MOMENTUM_UNIFIED_ALERT_TTL_HOURS=12

## Pivot output file read by momentum.py for unified alerts.
MOMENTUM_PIVOT_LEVELS_FILE=public_html/pivot_levels.json

## Session seeding (Twelve Data).
MOMENTUM_TD_SEED_WINDOW_MINUTES=20
MOMENTUM_STRICT_ONE_ATTEMPT_PER_WINDOW=true

## CRITICAL CHANGE:
## Set to false to prevent API calls on restart/cold start.
## When false, momentum.py relies on Stooq snapshots until the next session window.
MOMENTUM_ALLOW_BOOTSTRAP_ANYTIME=false
MOMENTUM_BOOTSTRAP_ANYTIME_PER_DAY=4
MOMENTUM_BOOTSTRAP_PER_RUN_MAX=4

## Prefer scraper-written Daily EMA seed over H1 reconstruction.
MOMENTUM_PREFER_SCRAPER_DAILY_EMA=true

## History / signal tuning.
## CRITICAL CHANGE:
## Increased to 4 hours to reduce repair requests on frequent restarts.
MOMENTUM_REPAIR_GAP_HOURS=4

#MOMENTUM_LOOKBACK_BARS=12
#MOMENTUM_EMA_FAST=8
#MOMENTUM_EMA_SIGNAL_FAST=20
#MOMENTUM_EMA_SIGNAL_SLOW=50
#MOMENTUM_PERSIST_WINDOW=6
#MOMENTUM_SIGNAL_FLOOR=0.01
#MOMENTUM_SEED_CLOSES_TARGET=60
#MOMENTUM_MAX_H1_HISTORY=500
#MOMENTUM_SNAPSHOT_RETENTION_DAYS=10
#MOMENTUM_DEFAULT_TIMEOUT=20

## Twelve Data rate-limit budget.
## Shared with pivot.py via momentum_td_usage.json if pivot reads same file.
#MOMENTUM_TD_REQUEST_LIMIT_PER_DAY=4
#MOMENTUM_TD_REQUESTS_PER_RUN_MAX=1
#MOMENTUM_TD_MIN_SECONDS_BETWEEN=10
#MOMENTUM_TD_429_COOLDOWN_MINUTES=60

## FX weekend window (UTC hours). Rarely needs changing.
#MOMENTUM_FX_WEEK_CLOSE_HOUR_UTC=22
#MOMENTUM_FX_WEEK_REOPEN_HOUR_UTC=22

## Market holidays.
MOMENTUM_MARKET_HOLIDAYS=
MOMENTUM_MARKET_HOLIDAYS_JSON=



## =============================================================================
## EMA ENGINE (ema.py)
## =============================================================================
## Output directory for ema_state.json, ema_closes.json, ema_stooq_snapshots.jsonl,
## and ema_twelvedata_usage.json. Must match EMA_DATA_DIR in the YML env block.
EMA_DATA_DIR=public_html

## How long after each FX session open (Sydney/Tokyo/London/New York) the
## Twelve Data broker-correction window stays open.
EMA_SESSION_WINDOW_MINUTES=20

## Require slow * EMA_WARMUP_MULTIPLIER completed bars before emitting signals.
## Set to 1 to restore minimal single-pass behaviour.
EMA_WARMUP_MULTIPLIER=1

## User-agent sent by ema.py to Stooq / Twelve Data. Defaults to Chrome UA.
#EMA_ANALYSIS_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36


## =============================================================================
## PIVOT ENGINE (pivot.py)
## =============================================================================
PIVOT_MAIN_PAIRS=eurusd,gbpusd,xauusd

PIVOT_DB=public_html/pivot.db
PIVOT_FORCE_REFRESH=0

## For live-only signal accuracy, keep this shorter than 30m.
## Daily OHLC still uses SQLite cache, so this does not mean daily OHLC is fetched every minute.
PIVOT_COMPONENTS_TTL=120

PIVOT_STOOQ_RSI_HISTORY_PERIOD=3mo

## Pivot levels / tolerances.
PRICE_PIVOT_BREAK_TOL=0.05
PRICE_PIVOT_REJECT_TOL=0.10
PRICE_PIVOT_BALANCE_BAND=0.15
PRICE_PIVOT_ATR_CAP=0.08

## ATR confirmation.
PRICE_ATR_CONFIRM_ENABLED=1
PRICE_ATR_CONFIRM_GATE_STATE=1
PRICE_ATR_CONFIRM_REQUIRE_AVAILABLE=0
PRICE_ATR_CONFIRM_BREAKOUT_MULT=0.10
PRICE_ATR_CONFIRM_ACCEPT_MULT=0.05
PRICE_ATR_CONFIRM_REJECTION_MULT=0.05

## Pivot-zone entry / SL / TP planning.
PRICE_PIVOT_TRADE_PLAN_ENABLED=1
PRICE_PIVOT_ENTRY_ZONE_ATR_MULT=0.05
PRICE_PIVOT_ENTRY_ZONE_RANGE_MULT=0.02
PRICE_PIVOT_SL_ATR_MULT=0.15
PRICE_PIVOT_SL_RANGE_MULT=0.03
PRICE_PIVOT_MIN_RR=1.20

## Conviction multipliers.
PRICE_CONV_WITH_BREAKOUT=1.10
PRICE_CONV_WITH_ACCEPT=1.00
PRICE_CONV_AGAINST_ACCEPT=0.85
PRICE_CONV_AGAINST_BREAKOUT=0.70
PRICE_CONV_REJECTION=0.75
PRICE_CONV_BALANCE=0.65
PRICE_CONV_NEUTRAL_MACRO=1.00
PRICE_PIVOT_NEUTRAL_MACRO=0.30

## RSI settings.
PRICE_RSI_PERIOD=14
#PRICE_RSI_OVERBOUGHT=70.0
#PRICE_RSI_OVERSOLD=30.0
#PRICE_RSI_BULLISH_LEVEL=55.0
#PRICE_RSI_BEARISH_LEVEL=45.0
#PRICE_RSI_WITH_MULT=1.05
#PRICE_RSI_AGAINST_MULT=0.95
#PRICE_RSI_NEUTRAL_MULT=1.00

## Shared Twelve Data run cap for pivot.
#PIVOT_TD_MAX_PER_RUN=4

## HTTP timeout for pivot API calls.
#PRICE_PIVOT_HTTP_TIMEOUT=10


## =============================================================================
## TELEGRAM ALERTS
## =============================================================================
## One token + one chat ID shared by ALL four scripts:
##   ema.py          → Daily EMA 20/50 cross alerts
##   momentum.py     → Hourly EMA 20/50 alerts (cross, proximity, imminent)
##   pivot.py        → Pivot structure alerts (breakout, rejection, accept)
##   signal_confirm.py → Combined pivot + EMA signal confirmation alerts
##
## Alert state files are created automatically in MOMENTUM_DATA_DIR / EMA_DATA_DIR.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

## EMA proximity / imminent-cross thresholds.
TELEGRAM_PROXIMITY_PCT=0.0015
TELEGRAM_CROSS_IMMINENT_PCT=0.0010

## Pivot alert quality gate.
PIVOT_ALERT_MIN_QUALITY=medium
PIVOT_ALERT_MIN_CONVICTION=0.80
#PIVOT_ALERT_STATE_PRUNE_H=26

### New York close pivot reset Telegram alerts.
### Sends one reset alert per pair when the new NY-close pivot session starts.
### 17:00 America/New_York auto-follows US daylight saving time.
PIVOT_RESET_ALERTS=1
PIVOT_RESET_ALERT_STATE_FILE=public_html/pivot_reset_telegram_alerts.json
PIVOT_NY_CLOSE_TZ=America/New_York
PIVOT_NY_CLOSE_HOUR=17
PIVOT_NY_CLOSE_MINUTE=0

### Groq AI enrichment for pivot Telegram alerts.
### Fill GROQ_API_KEY on the server only.
### If Groq AI fails, Telegram alerts still send without the AI note.
GROQ_AI_ENABLED=1
GROQ_API_KEY=
GROQ_AI_MODEL=llama-3.1-8b-instant
GROQ_AI_TIMEOUT=15
GROQ_AI_MAX_CHARS=700

#### Groq 429 protection / AI throttling.
#### Prevents repeated AI calls during alert bursts. Normal Telegram alerts still send if AI is skipped.
GROQ_AI_MAX_PER_RUN=20
GROQ_AI_COOLDOWN_MINUTES=30

## =============================================================================
## SIGNAL CONFIRMATION (signal_confirm.py)
## =============================================================================
SIGNAL_ALERT_MIN_CONFIDENCE=0.50
SIGNAL_ALERT_PRUNE_H=26
SIGNAL_ALERT_SIGNALS=confirmed_long,confirmed_short,high_conviction_long,high_conviction_short

## H1 intraday momentum context (reads momentum_closes.json — no API call).
SIGNAL_USE_H1_MOMENTUM=true
SIGNAL_H1_CLOSES_FILE=public_html/momentum_closes.json
SIGNAL_H1_MIN_BARS=20
SIGNAL_H1_WITH_BIAS_BONUS=0.05
SIGNAL_H1_AGAINST_BIAS_PENALTY=0.08
#SIGNAL_H1_FAST_EMA=20
#SIGNAL_H1_SLOW_EMA=50

# -----------------------------------------------------------------------------
# PIVOT H1 EMA20/50 INTEGRATION
# -----------------------------------------------------------------------------
# Used by pivot.py to align pivot alerts with the H1 EMA20/50 signal from momentum.py.
# Recommended: require alignment when EMA is available, but allow alerts if EMA data is
# missing/warming up so the bot does not go silent during bootstrap.
PIVOT_H1_EMA_ENABLED=1
PIVOT_H1_EMA_REQUIRE_ALIGNMENT=1
PIVOT_H1_EMA_ALLOW_MISSING=1
PIVOT_H1_EMA_BARS=0
PIVOT_H1_EMA_WITH_MULT=1.08
PIVOT_H1_EMA_AGAINST_MULT=0.72
PIVOT_H1_EMA_NEUTRAL_MULT=1.00

# -----------------------------------------------------------------------------
# SESSION CALENDAR / NEWS ALERTS (signal_confirm.py)
# -----------------------------------------------------------------------------
# Sends a Telegram digest of today's economic events once per FX session open.
# The scraper cron must run within SIGNAL_CALENDAR_SESSION_WINDOW_MIN minutes
# of the session start time for the alert to fire.

## Master switch.
SIGNAL_CALENDAR_ALERTS_ENABLED=true

## Impact filter — controls which events appear in the alert.
##   high   → 🔴 High impact only
##   medium → 🔴 High +  Medium
##   (empty)→ All impact levels
SIGNAL_CALENDAR_MIN_IMPACT=high

## Silently skip the alert if no events survive the impact filter.
## Set to false to send the message even when the filtered list is empty.
SIGNAL_CALENDAR_SKIP_IF_NO_EVENTS=true

## Currencies to include (comma-separated ISO codes).
SIGNAL_CALENDAR_CURRENCIES=EUR,GBP,USD

## Session open times in MYT at which to send the digest (name=HH:MM).
SIGNAL_CALENDAR_SESSIONS_MYT=Sydney=06:00,Tokyo=08:00,London=15:00,New York=20:00

## How many minutes after a session open the alert can still fire.
## Covers the case where the scraper cron fires slightly after the hour.
SIGNAL_CALENDAR_SESSION_WINDOW_MIN=45

## Maximum number of events to list in a single alert message.
SIGNAL_CALENDAR_MAX_EVENTS=14

## Groq AI calendar commentary (2-bullet summary appended to the digest).
## Requires GROQ_API_KEY and GROQ_AI_ENABLED=1 above.
SIGNAL_CALENDAR_GROQ_ENABLED=true

## Override path to calendar.json (leave blank to use SCRAPER_OUTPUT_DIR auto-detect).
#SIGNAL_CALENDAR_JSON=public_html/calendar.json
